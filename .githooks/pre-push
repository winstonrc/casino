#!/usr/bin/env bash
# Pre-push gate: the heavier checks CI also enforces. Kept off pre-commit so
# committing stays fast. Enable with: git config core.hooksPath .githooks
set -euo pipefail

echo "Running clippy (warnings denied)..."
cargo clippy --workspace --all-targets --all-features --locked -- -D warnings

echo "Running tests..."
cargo test --workspace --all-targets --locked

echo "Running documentation tests..."
cargo test --workspace --doc --locked

echo "Building strict public API documentation..."
RUSTDOCFLAGS="-D warnings -D missing_docs" cargo doc --workspace --no-deps --locked

echo "All checks passed."
